{
  "ConnectionStrings": {
    "KreditzBankData": ""
  },
  "IngestionOptions": {
    "ArrivedFolder": "../Files/Arrived",
    "ProcessedFolder": "../Files/Processed",
    "DuplicatesFolder": "../Files/Duplicates",
    "ErrorFolder": "../Files/Error",
    "PollingIntervalSeconds": 200
  },
  "AnomalyDetectionOptions": {
    "LargeTransactionThreshold": 10000.00,
    "HighFrequencyWindowMinutes": 60,
    "HighFrequencyTransactionCount": 10
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/ingestion-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  }
}
